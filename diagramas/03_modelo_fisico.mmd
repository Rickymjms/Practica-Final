erDiagram
    %% Modelo Físico - Presupuesto Nacional RD (SQL Server)
    %% Autor: Lic. Manuel Mañana Santana

    Dim_Institucion ||--o{ Fact_Ejecucion : "id_institucion"
    Dim_Geografia ||--o{ Fact_Ejecucion : "id_geografia"
    Dim_Programa ||--o{ Fact_Ejecucion : "id_programa"
    Dim_Objeto_Gasto ||--o{ Fact_Ejecucion : "id_objeto_gasto"
    Dim_Tiempo ||--o{ Fact_Ejecucion : "id_tiempo"

    Dim_Institucion {
        INT id_institucion PK "IDENTITY"
        NVARCHAR_20 cod_capitulo "NOT NULL"
        NVARCHAR_255 capitulo "NOT NULL"
        NVARCHAR_20 cod_subcapitulo
        NVARCHAR_255 subcapitulo
        NVARCHAR_20 cod_unidad_ejecutora
        NVARCHAR_255 unidad_ejecutora
    }

    Dim_Geografia {
        INT id_geografia PK "IDENTITY"
        NVARCHAR_10 cod_region
        NVARCHAR_100 region
        NVARCHAR_10 cod_provincia
        NVARCHAR_100 provincia
        NVARCHAR_10 cod_municipio
        NVARCHAR_100 municipio
    }

    Dim_Programa {
        INT id_programa PK "IDENTITY"
        NVARCHAR_20 cod_programa
        NVARCHAR_255 programa
        NVARCHAR_20 cod_producto
        NVARCHAR_255 producto
        NVARCHAR_20 cod_proyecto
        NVARCHAR_255 proyecto
        NVARCHAR_20 cod_actividad
        NVARCHAR_255 actividad
    }

    Dim_Objeto_Gasto {
        INT id_objeto_gasto PK "IDENTITY"
        NVARCHAR_10 cod_tipo
        NVARCHAR_100 tipo
        NVARCHAR_10 cod_concepto
        NVARCHAR_100 concepto
        NVARCHAR_10 cod_cuenta
        NVARCHAR_100 cuenta
        NVARCHAR_10 cod_subcuenta
        NVARCHAR_100 subcuenta
        NVARCHAR_10 cod_auxiliar
        NVARCHAR_100 auxiliar
    }

    Dim_Tiempo {
        INT id_tiempo PK "IDENTITY"
        INT periodo_anio "NOT NULL"
        INT mes_imputacion "NOT NULL"
        NVARCHAR_20 nombre_mes "NOT NULL"
    }

    Fact_Ejecucion {
        BIGINT id_ejecucion PK "IDENTITY"
        INT id_institucion FK
        INT id_geografia FK
        INT id_programa FK
        INT id_objeto_gasto FK
        INT id_tiempo FK
        DECIMAL_18_2 presupuesto_inicial "DEFAULT 0"
        DECIMAL_18_2 presupuesto_vigente "DEFAULT 0"
        DECIMAL_18_2 devengado_aprobado "DEFAULT 0"
    }
